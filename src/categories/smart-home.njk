---
layout: base.njk
title: "Smart Home Reviews & Buying Guides"
description: "Robot vacuums, smart speakers, and home automation gear — honest reviews of what actually works."
permalink: /categories/smart-home/index.html
categorySlug: smart-home
---
<section class="section">
  <div class="section-inner">
    <h1 class="section-title">Smart Home</h1>
    <p class="section-subtitle">Robot vacuums, smart speakers, and home automation gear — honest reviews of what actually works.</p>
    <div class="article-grid">
      {% for article in collections.articlesByDate %}
        {% if article.data.category == "smart-home" %}
        <article class="article-card">
          <div class="card-body">
            <span class="card-category">Smart Home</span>
            <a href="{{ article.url | url }}" style="display:block">
              <h2 class="card-title">{{ article.data.title }}</h2>
            </a>
            <p class="card-excerpt">{{ article.data.description | truncate(120) }}</p>
            <div class="card-meta">
              <span>{{ article.date | postDate }}</span>
            </div>
            <a href="{{ article.url | url }}" class="read-more" style="margin-top:0.75rem;display:inline-flex">Read guide →</a>
          </div>
        </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
