---
layout: base.njk
title: "Fitness Reviews & Buying Guides"
description: "Dumbbells, resistance equipment, and fitness gear reviewed for real people with real budgets."
permalink: /categories/fitness/index.html
categorySlug: fitness
---
<section class="section">
  <div class="section-inner">
    <h1 class="section-title">Fitness</h1>
    <p class="section-subtitle">Dumbbells, resistance equipment, and fitness gear reviewed for real people with real budgets.</p>
    <div class="article-grid">
      {% for article in collections.articlesByDate %}
        {% if article.data.category == "fitness" %}
        <article class="article-card">
          <div class="card-body">
            <span class="card-category">Fitness</span>
            <a href="{{ article.url }}" style="display:block">
              <h2 class="card-title">{{ article.data.title }}</h2>
            </a>
            <p class="card-excerpt">{{ article.data.description | truncate(120) }}</p>
            <div class="card-meta">
              <span>{{ article.date | postDate }}</span>
            </div>
            <a href="{{ article.url }}" class="read-more" style="margin-top:0.75rem;display:inline-flex">Read guide →</a>
          </div>
        </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
