---
layout: base.njk
title: "Pet Tech Reviews & Buying Guides"
description: "GPS trackers, smart feeders, and the best tech gear for your pet."
permalink: /categories/pet-tech/index.html
categorySlug: pet-tech
---
<section class="section">
  <div class="section-inner">
    <h1 class="section-title">Pet Tech</h1>
    <p class="section-subtitle">GPS trackers, smart feeders, and the best tech gear for your pet.</p>
    <div class="article-grid">
      {% for article in collections.articlesByDate %}
        {% if article.data.category == "pet-tech" %}
        <article class="article-card">
          <div class="card-body">
            <span class="card-category">Pet Tech</span>
            <a href="{{ article.url }}" style="display:block">
              <h2 class="card-title">{{ article.data.title }}</h2>
            </a>
            <p class="card-excerpt">{{ article.data.description | truncate(120) }}</p>
            <div class="card-meta">
              <span>{{ article.date | postDate }}</span>
            </div>
            <a href="{{ article.url }}" class="read-more" style="margin-top:0.75rem;display:inline-flex">Read guide →</a>
          </div>
        </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
