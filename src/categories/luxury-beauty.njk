permalink: /categories/luxury-beauty/index.html
categorySlug: luxury-beauty
---
<section class="section">
  <div class="section-inner">
    <h1 class="section-title">Luxury Beauty</h1>
    <p class="section-subtitle">Serums, moisturizers, and skincare that actually work — with honest commission-free rankings.</p>
    <div class="article-grid">
      {% for article in collections.articlesByDate %}
        {% if article.data.category == "luxury-beauty" %}
        <article class="article-card">
          <div class="card-body">
            <span class="card-category">Luxury Beauty</span>
            <a href="{{ article.url }}" style="display:block">
              <h2 class="card-title">{{ article.data.title }}</h2>
            </a>
            <p class="card-excerpt">{{ article.data.description | truncate(120) }}</p>
            <div class="card-meta">
              <span>{{ article.date | postDate }}</span>
            </div>
            <a href="{{ article.url }}" class="read-more" style="margin-top:0.75rem;display:inline-flex">Read guide →</a>
          </div>
        </article>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>
