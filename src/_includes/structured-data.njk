{# WebSite schema — sitewide, enables Google Sitelinks Search Box #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "NickPicks",
  "url": {{ siteUrl | dump | safe }},
  "description": "Independent product reviews and buying guides for home office, beauty, fitness, kitchen, and pet tech.",
  "potentialAction": {
    "@type": "SearchAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": {{ (siteUrl + "/search/?q={search_term_string}") | dump | safe }}
    },
    "query-input": "required name=search_term_string"
  }
}
</script>

{# BreadcrumbList — all pages #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": {{ siteUrl | dump | safe }}}
    {% if layout == "article.njk" %},
    {"@type": "ListItem", "position": 2, "name": {{ (category | categoryLabel) | dump | safe }}, "item": {{ (siteUrl + (category | categoryHub)) | dump | safe }}},
    {"@type": "ListItem", "position": 3, "name": {{ title | dump | safe }}, "item": {{ (siteUrl + (page.url | stripPathPrefix)) | dump | safe }}}
    {% elif title and page.url and (page.url | stripPathPrefix) != "/" %},
    {"@type": "ListItem", "position": 2, "name": {{ title | dump | safe }}, "item": {{ (siteUrl + (page.url | stripPathPrefix)) | dump | safe }}}
    {% endif %}
  ]
}
</script>

{# Article schema for article pages #}
{% if layout == "article.njk" %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  "datePublished": "{{ date | date("yyyy-MM-dd") }}",
  "dateModified": "{{ (dateModified or date) | date("yyyy-MM-dd") }}",
  "url": {{ (siteUrl + (page.url | stripPathPrefix)) | dump | safe }},
  "image": {{ (siteUrl + (ogImage or site.defaultOgImage)) | dump | safe }},
  "author": {
    "@type": "Person",
    "name": "Nick",
    "url": "https://nickpicks.com/about"
  },
  "publisher": {
    "@type": "Organization",
    "name": "NickPicks",
    "url": {{ siteUrl | dump | safe }},
    "logo": {
      "@type": "ImageObject",
      "url": {{ (siteUrl + "/images/favicon.png") | dump | safe }}
    }
  }
}
</script>

{# ItemList schema for listicle articles with products frontmatter #}
{% if products and products.length %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  "numberOfItems": {{ products.length }},
  "url": {{ (siteUrl + (page.url | stripPathPrefix)) | dump | safe }},
  "itemListElement": [
    {% for product in products %}
    {
      "@type": "ListItem",
      "position": {{ product.position }},
      "name": {{ product.name | dump | safe }}{% if product.description %},
      "description": {{ product.description | dump | safe }}{% endif %}
    }{% if not loop.last %},{% endif %}

    {% endfor %}
  ]
}
</script>
{% endif %}

{# FAQPage schema for articles with faqs frontmatter #}
{% if faqs and faqs.length %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for faq in faqs %}
    {
      "@type": "Question",
      "name": {{ faq.question | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ faq.answer | dump | safe }}
      }
    }{% if not loop.last %},{% endif %}

    {% endfor %}
  ]
}
</script>
{% endif %}

{# Product + Review schema for single-product review articles #}
{% if reviewProduct %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Product",
  "name": {{ reviewProduct | dump | safe }},
  "brand": {
    "@type": "Brand",
    "name": {{ reviewBrand | dump | safe }}
  },{% if reviewPrice %}
  "offers": {
    "@type": "Offer",
    "priceCurrency": "USD",
    "price": "{{ reviewPrice }}",
    "availability": "https://schema.org/InStock"
  },{% endif %}
  "review": {
    "@type": "Review",
    "reviewRating": {
      "@type": "Rating",
      "ratingValue": "{{ reviewRating }}",
      "bestRating": "5",
      "worstRating": "1"
    },
    "author": {
      "@type": "Person",
      "name": "Nick",
      "url": "https://nickpicks.com/about"
    },
    "reviewBody": {{ description | dump | safe }},
    "publisher": {
      "@type": "Organization",
      "name": "NickPicks",
      "url": {{ siteUrl | dump | safe }}
    }
  }
}
</script>
{% endif %}
{% endif %}

{# ItemList for category pages (requires categorySlug frontmatter) #}
{% if categorySlug %}
{% set catArticles = collections.articlesByDate | whereCategory(categorySlug) %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ title | dump | safe }},
  "url": {{ (siteUrl + (page.url | stripPathPrefix)) | dump | safe }},
  "itemListElement": [
    {% for article in catArticles %}
    {"@type": "ListItem", "position": {{ loop.index }}, "name": {{ article.data.title | dump | safe }}, "url": {{ (siteUrl + (article.url | stripPathPrefix)) | dump | safe }}}{% if not loop.last %},{% endif %}

    {% endfor %}
  ]
}
</script>
{% endif %}
