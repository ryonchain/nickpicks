{# BreadcrumbList — all pages #}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {"@type": "ListItem", "position": 1, "name": "Home", "item": {{ siteUrl | dump | safe }}}
    {% if layout == "article.njk" %},
    {"@type": "ListItem", "position": 2, "name": {{ (category | categoryLabel) | dump | safe }}, "item": {{ (siteUrl + "/categories/" + category + "/") | dump | safe }}},
    {"@type": "ListItem", "position": 3, "name": {{ title | dump | safe }}, "item": {{ (siteUrl + (page.url | stripPathPrefix)) | dump | safe }}}
    {% elif title and page.url and (page.url | stripPathPrefix) != "/" %},
    {"@type": "ListItem", "position": 2, "name": {{ title | dump | safe }}, "item": {{ (siteUrl + (page.url | stripPathPrefix)) | dump | safe }}}
    {% endif %}
  ]
}
</script>

{# Article schema for article pages #}
{% if layout == "article.njk" %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  "datePublished": "{{ date | date("yyyy-MM-dd") }}",
  "dateModified": "{{ (dateModified or date) | date("yyyy-MM-dd") }}",
  "url": {{ (siteUrl + (page.url | stripPathPrefix)) | dump | safe }},
  "publisher": {
    "@type": "Organization",
    "name": "NickPicks",
    "url": {{ siteUrl | dump | safe }}
  },
  "author": {
    "@type": "Organization",
    "name": "NickPicks Editorial"
  }
}
</script>

{# ItemList schema for listicle articles with products frontmatter #}
{% if products and products.length %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ title | dump | safe }},
  "description": {{ description | dump | safe }},
  "numberOfItems": {{ products.length }},
  "url": {{ (siteUrl + (page.url | stripPathPrefix)) | dump | safe }},
  "itemListElement": [
    {% for product in products %}
    {
      "@type": "ListItem",
      "position": {{ product.position }},
      "name": {{ product.name | dump | safe }}{% if product.description %},
      "description": {{ product.description | dump | safe }}{% endif %}
    }{% if not loop.last %},{% endif %}

    {% endfor %}
  ]
}
</script>
{% endif %}
{% endif %}

{# ItemList for category pages (requires categorySlug frontmatter) #}
{% if categorySlug %}
{% set catArticles = collections.articlesByDate | whereCategory(categorySlug) %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": {{ title | dump | safe }},
  "url": {{ (siteUrl + (page.url | stripPathPrefix)) | dump | safe }},
  "itemListElement": [
    {% for article in catArticles %}
    {"@type": "ListItem", "position": {{ loop.index }}, "name": {{ article.data.title | dump | safe }}, "url": {{ (siteUrl + (article.url | stripPathPrefix)) | dump | safe }}}{% if not loop.last %},{% endif %}

    {% endfor %}
  ]
}
</script>
{% endif %}
