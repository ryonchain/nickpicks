---
layout: base.njk
---

<div id="reading-progress-bar" aria-hidden="true"></div>

{# Pagefind metadata: title and description are indexed from these hidden elements #}
<span data-pagefind-meta="title" style="display:none">{{ title }}</span>
<span data-pagefind-meta="description" style="display:none">{{ description }}</span>
{% if ogImage %}<meta data-pagefind-meta="image[content]" content="{{ ogImage }}" />{% endif %}

<div class="article-page-layout">

  <article data-pagefind-body>
    <header class="article-header">
      <span class="category-tag"><a href="{{ (category | categoryHub) | url }}">{{ category | categoryLabel }}</a></span>
      <h1>{{ title }}</h1>
      <div class="article-meta">
        <span>{{ date | postDate }}</span>
        <span>·</span>
        <span>{{ content | readingTime }} min read</span>
      </div>
    </header>

    <div class="disclosure-box" data-pagefind-ignore>
      <strong>Affiliate Disclosure:</strong> This article contains Amazon affiliate links. If you purchase through our links, we may earn a commission at no extra cost to you. Our recommendations are always independent and based on merit.
    </div>

    {% if comparisonTable %}
    {% include "components/comparison-table.njk" %}
    {% endif %}

    <div class="article-body">
      {{ content | safe }}
    </div>

    {% include "related-articles.njk" %}

    {% set canonicalUrl = siteUrl + (page.url | stripPathPrefix) %}
    <div class="share-buttons" data-pagefind-ignore>
      <span class="share-label">Share this article:</span>
      <a class="share-btn share-btn--x"
         href="https://twitter.com/intent/tweet?url={{ canonicalUrl | urlencode }}&text={{ title | urlencode }}"
         target="_blank" rel="noopener noreferrer" aria-label="Share on X (Twitter)">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.737-8.835L1.254 2.25H8.08l4.258 5.632 5.906-5.632zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        Share on X
      </a>
      <a class="share-btn share-btn--facebook"
         href="https://www.facebook.com/sharer/sharer.php?u={{ canonicalUrl | urlencode }}"
         target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        Share on Facebook
      </a>
      <button class="share-btn share-btn--copy"
              data-url="{{ canonicalUrl }}"
              onclick="(function(btn){navigator.clipboard.writeText(btn.dataset.url).then(function(){var orig=btn.innerHTML;btn.innerHTML='&#x2713; Copied!';setTimeout(function(){btn.innerHTML=orig},2000)});})(this)"
              aria-label="Copy link to clipboard">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>
        Copy Link
      </button>
    </div>
  </article>

  <aside class="sidebar">
    <div class="sidebar-widget">
      <h3>Related Articles</h3>
      <ul class="sidebar-links">
        {% set relatedArticles = collections.articlesByDate | selectattr("data.category", category) %}
        {% for item in collections.articlesByDate %}
          {% if item.data.category == category and (item.url | url) != page.url %}
            <li><a href="{{ item.url | url }}">{{ item.data.title }}</a></li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
    <div class="sidebar-widget">
      <h3>Popular Guides</h3>
      <ul class="sidebar-links">
        {% for item in collections.articlesByDate | slice(0, 5) %}
          {% if (item.url | url) != page.url %}
            <li><a href="{{ item.url | url }}">{{ item.data.title }}</a></li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
    <div class="sidebar-widget newsletter-widget">
      <h3>Get Weekly Picks</h3>
      <p class="newsletter-widget-desc">Our best finds, straight to your inbox. No spam, ever.</p>
      <form class="newsletter-form">
        <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
        <button type="submit">Subscribe Free</button>
        <p class="kit-error" role="alert" style="color:#c00;font-size:0.85rem;margin-top:0.4rem"></p>
      </form>
    </div>
  </aside>

  <section class="article-cta-newsletter">
    <div class="article-cta-inner">
      <h2>Get Weekly Picks</h2>
      <p>Our best finds, straight to your inbox. One email a week — no spam.</p>
      <form class="newsletter-form newsletter-form--inline">
        <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
        <button type="submit">Subscribe Free</button>
        <p class="kit-error" role="alert" style="color:#fca5a5;font-size:0.85rem;margin-top:0.5rem"></p>
      </form>
    </div>
  </section>

</div>

<script>
(function () {
  var bar = document.getElementById('reading-progress-bar');
  if (!bar) return;
  function update() {
    var scrollTop = window.scrollY || document.documentElement.scrollTop;
    var docHeight = document.documentElement.scrollHeight - document.documentElement.clientHeight;
    var pct = docHeight > 0 ? (scrollTop / docHeight) * 100 : 0;
    bar.style.width = Math.min(pct, 100) + '%';
  }
  window.addEventListener('scroll', update, { passive: true });
  update();
}());
</script>
