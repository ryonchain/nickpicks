---
layout: base.njk
---

{# Pagefind metadata: title and description are indexed from these hidden elements #}
<span data-pagefind-meta="title" style="display:none">{{ title }}</span>
<span data-pagefind-meta="description" style="display:none">{{ description }}</span>
{% if ogImage %}<meta data-pagefind-meta="image[content]" content="{{ ogImage }}" />{% endif %}

<div class="article-page-layout">

  <article data-pagefind-body>
    <header class="article-header">
      <span class="category-tag"><a href="{{ (category | categoryHub) | url }}">{{ category | categoryLabel }}</a></span>
      <h1>{{ title }}</h1>
      <div class="article-meta">
        <span>{{ date | postDate }}</span>
        <span>·</span>
        <span>{{ content | readingTime }} min read</span>
      </div>
    </header>

    <div class="disclosure-box" data-pagefind-ignore>
      <strong>Affiliate Disclosure:</strong> This article contains Amazon affiliate links. If you purchase through our links, we may earn a commission at no extra cost to you. Our recommendations are always independent and based on merit.
    </div>

    <div class="article-body">
      {{ content | safe }}
    </div>
  </article>

  <aside class="sidebar">
    <div class="sidebar-widget">
      <h3>Related Articles</h3>
      <ul class="sidebar-links">
        {% set relatedArticles = collections.articlesByDate | selectattr("data.category", category) %}
        {% for item in collections.articlesByDate %}
          {% if item.data.category == category and (item.url | url) != page.url %}
            <li><a href="{{ item.url | url }}">{{ item.data.title }}</a></li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
    <div class="sidebar-widget">
      <h3>Popular Guides</h3>
      <ul class="sidebar-links">
        {% for item in collections.articlesByDate | slice(0, 5) %}
          {% if (item.url | url) != page.url %}
            <li><a href="{{ item.url | url }}">{{ item.data.title }}</a></li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
    <div class="sidebar-widget newsletter-widget">
      <h3>Get Weekly Picks</h3>
      <p class="newsletter-widget-desc">Our best finds, straight to your inbox. No spam, ever.</p>
      <form class="newsletter-form">
        <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
        <button type="submit">Subscribe Free</button>
        <p class="kit-error" role="alert" style="color:#c00;font-size:0.85rem;margin-top:0.4rem"></p>
      </form>
    </div>
  </aside>

  <section class="article-cta-newsletter">
    <div class="article-cta-inner">
      <h2>Get Weekly Picks</h2>
      <p>Our best finds, straight to your inbox. One email a week — no spam.</p>
      <form class="newsletter-form newsletter-form--inline">
        <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
        <button type="submit">Subscribe Free</button>
        <p class="kit-error" role="alert" style="color:#fca5a5;font-size:0.85rem;margin-top:0.5rem"></p>
      </form>
    </div>
  </section>

</div>
