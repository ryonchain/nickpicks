<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ title }} {% if title %} | {% endif %}NickPicks — Honest Reviews &amp; Buying Guides</title>
  <meta name="description" content="{{ description | default('NickPicks publishes honest product reviews and buying guides to help you find the best gear for home office, beauty, fitness, kitchen, and pet tech.') }}" />
  <link rel="canonical" href="{{ siteUrl }}{{ page.url | stripPathPrefix }}" />
  <meta property="og:title" content="{{ ogTitle or title }} | NickPicks" />
  <meta property="og:description" content="{{ ogDescription or description or site.description }}" />
  <meta property="og:image" content="{{ siteUrl }}{{ ogImage or site.defaultOgImage }}" />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:type" content="{% if layout == 'article.njk' %}article{% else %}website{% endif %}" />
  <meta property="og:url" content="{{ siteUrl }}{{ page.url | stripPathPrefix }}" />
  <meta property="og:site_name" content="NickPicks" />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:site" content="{{ site.twitterHandle }}" />
  <meta name="twitter:title" content="{{ ogTitle or title }} | NickPicks" />
  <meta name="twitter:description" content="{{ ogDescription or description or site.description }}" />
  <meta name="twitter:image" content="{{ siteUrl }}{{ ogImage or site.defaultOgImage }}" />
  <!-- Preconnect to external origins to reduce DNS lookup time -->
  <link rel="preconnect" href="https://www.googletagmanager.com">
  <link rel="preconnect" href="https://www.google-analytics.com">
  <link rel="preconnect" href="https://m.media-amazon.com" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link rel="icon" type="image/png" href="{{ '/images/favicon.png' | url }}" />
  <!-- Critical above-the-fold CSS inlined to eliminate render-blocking -->
  <style>
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    :root{--color-primary:#1a56db;--color-primary-dark:#1140a0;--color-bg:#ffffff;--color-surface:#f8fafc;--color-border:#e2e8f0;--color-text:#1a202c;--color-text-muted:#64748b;--color-accent:#f59e0b;--font-sans:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;--max-w:1100px;--max-w-article:740px}
    html{font-size:16px}
    body{font-family:var(--font-sans);color:var(--color-text);background:var(--color-bg);line-height:1.6}
    a{color:var(--color-primary);text-decoration:none}
    img{max-width:100%;display:block}
    .site-header{border-bottom:1px solid var(--color-border);background:var(--color-bg);position:sticky;top:0;z-index:100}
    .site-header .inner{max-width:var(--max-w);margin:0 auto;padding:0 1.5rem;display:flex;align-items:center;justify-content:space-between;height:60px}
    .logo{font-size:1.3rem;font-weight:700;color:var(--color-text);letter-spacing:-.02em}
    .logo span{color:var(--color-primary)}
    .nav-links{display:flex;gap:1.5rem;list-style:none}
    .nav-links a{font-size:.9rem;font-weight:500;color:var(--color-text-muted)}
    .nav-best-sellers{background:var(--color-accent);color:#1a202c!important;padding:.3rem .75rem;border-radius:4px;font-weight:700}
    .header-search{display:flex;align-items:center;gap:0;margin-left:1rem}
    .header-search-input{border:1px solid var(--color-border);border-right:none;border-radius:6px 0 0 6px;padding:.35rem .7rem;font-size:.85rem;color:var(--color-text);background:var(--color-surface);width:160px;outline:none}
    .header-search-btn{border:1px solid var(--color-border);border-left:none;border-radius:0 6px 6px 0;background:var(--color-primary);color:#fff;padding:.35rem .6rem;cursor:pointer;display:flex;align-items:center}
    .hero{background:linear-gradient(135deg,#1e3a5f 0%,#1a56db 100%);color:#fff;padding:4rem 1.5rem;text-align:center}
    .hero h1{font-size:2.5rem;font-weight:800;line-height:1.2;margin-bottom:1rem}
    .hero p{font-size:1.15rem;opacity:.85;max-width:540px;margin:0 auto 1.75rem}
    .btn-primary{display:inline-block;background:var(--color-accent);color:#1a202c;font-weight:700;padding:.75rem 2rem;border-radius:6px;font-size:1rem}
    .article-page-layout{max-width:var(--max-w);margin:0 auto;padding:2.5rem 1.5rem 4rem;display:grid;grid-template-columns:1fr 280px;gap:3rem}
    .article-header{margin-bottom:2rem}
    .article-header .category-tag{display:inline-block;font-size:.75rem;font-weight:700;text-transform:uppercase;letter-spacing:.06em;color:var(--color-primary);background:#eff6ff;padding:.25rem .6rem;border-radius:4px;margin-bottom:.75rem}
    .article-header h1{font-size:2rem;font-weight:800;line-height:1.25;margin-bottom:1rem}
    .hub-hero{background:var(--color-surface);border-bottom:1px solid var(--color-border);padding:2.5rem 1.5rem}
    .hub-hero h1{font-size:1.9rem;font-weight:800;line-height:1.25;margin-bottom:.75rem}
    .disclosure-box{background:#fffbeb;border:1px solid #fde68a;border-radius:8px;padding:1rem 1.25rem;font-size:.875rem;color:#92400e;margin-bottom:2rem}
    @media(max-width:640px){.header-search{display:none}}
    @media(max-width:768px){.nav-links{display:none}.article-page-layout{grid-template-columns:1fr}.hero h1{font-size:1.75rem}.article-header h1{font-size:1.5rem}.hub-hero h1{font-size:1.5rem}}
  </style>
  <!-- Full stylesheet deferred to avoid render-blocking -->
  <link rel="preload" href="{{ '/style.css' | url }}" as="style" onload="this.onload=null;this.rel='stylesheet'">
  <noscript><link rel="stylesheet" href="{{ '/style.css' | url }}"></noscript>
  <link rel="alternate" type="application/rss+xml" href="{{ '/feed.xml' | url }}" title="NickPicks" />
  {% include "structured-data.njk" %}
  {% if site.ga4MeasurementId and site.ga4MeasurementId != "G-XXXXXXXXXX" %}
  <!-- Google tag (gtag.js) -->
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.ga4MeasurementId }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.ga4MeasurementId }}');
  </script>
  {% endif %}
  <script>window.NP_KIT = { formId: "{{ site.kitFormId }}", publicKey: "{{ site.kitPublicKey }}" };</script>
  <script src="{{ '/js/kit-subscribe.js' | url }}" defer></script>
</head>
<body>

<header class="site-header" data-pagefind-ignore>
  <div class="inner">
    <a class="logo" href="{{ '/' | url }}">Nick<span>Picks</span></a>
    <nav aria-label="Main navigation">
      <ul class="nav-links">
        <li><a href="{{ '/home-office/' | url }}">Home Office</a></li>
        <li><a href="{{ '/beauty/' | url }}">Beauty</a></li>
        <li><a href="{{ '/fitness/' | url }}">Fitness</a></li>
        <li><a href="{{ '/kitchen/' | url }}">Kitchen</a></li>
        <li><a href="{{ '/pet-tech/' | url }}">Pet Tech</a></li>
        <li><a href="{{ '/best-sellers/' | url }}" class="nav-best-sellers">Best Sellers</a></li>
      </ul>
    </nav>
    <form class="header-search" action="{{ '/search/' | url }}" method="get" role="search">
      <input
        type="search"
        name="q"
        placeholder="Search picks…"
        aria-label="Search NickPicks"
        class="header-search-input"
      />
      <button type="submit" class="header-search-btn" aria-label="Search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
    </form>
  </div>
</header>

<main id="main-content">
  {{ content | safe }}
</main>

<footer class="site-footer" data-pagefind-ignore>
  <div class="footer-inner">
    <div class="footer-cols">
      <div>
        <div class="footer-brand">Nick<span>Picks</span></div>
        <p class="footer-about">Independent reviews and buying guides. We test, compare, and rank products so you don't have to waste money on the wrong gear.</p>
      </div>
      <div>
        <div class="footer-heading">Categories</div>
        <ul class="footer-links">
          <li><a href="{{ '/home-office/' | url }}">Home Office</a></li>
          <li><a href="{{ '/beauty/' | url }}">Beauty</a></li>
          <li><a href="{{ '/fitness/' | url }}">Fitness</a></li>
          <li><a href="{{ '/kitchen/' | url }}">Kitchen</a></li>
          <li><a href="{{ '/pet-tech/' | url }}">Pet Tech</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-heading">Site</div>
        <ul class="footer-links">
          <li><a href="{{ '/' | url }}">Home</a></li>
          <li><a href="{{ '/best-sellers/' | url }}">Best Sellers</a></li>
          <li><a href="{{ '/about/' | url }}">About</a></li>
          <li><a href="{{ '/contact/' | url }}">Contact</a></li>
          <li><a href="{{ '/privacy/' | url }}">Privacy Policy</a></li>
          <li><a href="{{ '/affiliate-disclosure/' | url }}">Affiliate Disclosure</a></li>
        </ul>
      </div>
      <div>
        <div class="footer-heading">Newsletter</div>
        <p class="footer-about" style="margin-bottom:0.75rem">Weekly desk setup finds &amp; top picks — straight to your inbox.</p>
        <form class="newsletter-form newsletter-form--footer">
          <input type="text" name="first_name" placeholder="First name" aria-label="First name" />
          <input type="email" name="email" placeholder="your@email.com" required aria-label="Email address" />
          <button type="submit">Subscribe</button>
          <p class="kit-error" role="alert" style="color:#c00;font-size:0.85rem;margin-top:0.4rem"></p>
        </form>
      </div>
    </div>
    <div class="footer-disclaimer">
      <strong>Amazon Affiliate Disclosure:</strong> NickPicks is a participant in the Amazon Services LLC Associates Program, an affiliate advertising program designed to provide a means for sites to earn advertising fees by advertising and linking to Amazon.com. As an Amazon Associate, we earn from qualifying purchases. This means if you click on an Amazon link and make a purchase, we may receive a small commission at no extra cost to you. Our editorial opinions are never influenced by compensation — we only recommend products we believe deliver real value.
    </div>
    <p class="footer-copy">&copy; {{ "" | date("yyyy") | default("2026") }} NickPicks. All rights reserved.</p>
  </div>
</footer>

</body>
</html>
